def load_article_content(article):
    """โหลด content จากไฟล์ ถ้า content เป็น path (เริ่มต้นด้วย 'file:')"""
    content = article.get('content', '')
    if content.startswith('file:'):
        filepath = content[5:].strip()  # ตัด 'file:' ออก
        try:
            with open(filepath, 'r', encoding='utf-8') as f:
                return f.read()
        except Exception as e:
            print(f❌ ไม่สามารถอ่านไฟล์ {filepath}: {e})
            return content
    return content

def generate_image(episode, prompt, output_path):
    """สร้างรูปภาพปกด้วย ImageMagick"""
    print(f"🎨 กําลังสร้างรูปปกสําหรับตอนที่ {episode}...")

    # ข้อความบนรูป
    episode_text = f"ตอนที่ {episode}"
    title_text = ARTICLES[episode]["title"]

    # สร้างรูปด้วย ImageMagick (1200x900 = 4:3)
    cmd = f"""
    convert -size 1200x900 xc:#1a365d \
        -fill white -gravity center \
        -font Garuda -pointsize 72 \
        -annotate +0-150 '{episode_text}' \
        -font Garuda -pointsize 48 \
        -annotate +0+50 '{title_text}' \
        -font Garuda -pointsize 24 \
        -annotate +0+200 'Nub-1 Channel | โซล่าเซลล์' \
        -quality 90 {output_path}
    """

    try:
        subprocess.run(cmd, shell=True, check=True, capture_output=True)
        print(f"✅ รูปภาพบันทึกที่: {output_path}")
        return True
    except subprocess.CalledProcessError as e:
        print(f"❌ สร้างรูปไม่สําเร็จ: {e}")
        return False

def save_markdown(episode, content):
    """บันทึกไฟล์ .md """
    filepath = f"{ARTICLES_DIR}/{episode:02d}-{ARTICLES[episode]['slug']}.md"
    with open(filepath, 'w', encoding='utf-8') as f:
        f.write(content)
    print(f"✅ บันทึกบทความที่: {filepath}")
    return filepath

def upload_wordpress(episode, title, content, image_path, slug):
    """อัปโหลดขึ้น WordPress"""
    print(f"📝 กําลังอัปโหลดขึ้น WordPress...")

    # อัปโหลดรูปภาพ
    with open(image_path, 'rb') as img:
        files = {'file': img}
        data = {
            'title': f"Solar Episode {episode}: {title}",
            'alt_text': title
        }
        r = requests.post(
            f"{BLOG_URL}/wp-json/wp/v2/media",
            auth=(WP_USER, WP_APP_PASSWORD),
            files=files,
            data=data
        )

    if r.status_code == 201:
        media_id = r.json()['id']
        media_url = r.json()['source_url']
        print(f"✅ รูปภาพอัปโหลดแล้ว (ID: {media_id})")
    else:
        print(f"⚠️ อัปโหลดรูปไม่สําเร็จ: {r.text}")
        media_id = None
        media_url = None

    # สร้างโพสต์
    post_data = {
        'title': title,
        'content': content,
        'status': 'publish',
        'categories': [WP_CATEGORY_ID],
        'slug': slug,
        'featured_media': media_id
    }

    r = requests.post(
        f"{BLOG_URL}/wp-json/wp/v2/posts",
        auth=(WP_USER, WP_APP_PASSWORD),
        json=post_data
    )

    if r.status_code == 201:
        post_url = r.json()['link']
        print(f"✅ โพสต์สร้างแล้ว: {post_url}")
        return post_url
    else:
        print(f"❌ สร้างโพสต์ไม่สําเร็จ: {r.text}")
        return None

def push_to_github(episode):
    """Push ขึ้น GitHub """
    print(f"📤 กําลัง push ขึ้น GitHub...")

    os.chdir(GITHUB_REPO)
    subprocess.run(['git', 'add', '.'], check=True)
    subprocess.run(['git', 'commit', '-m', f'เพิ่มบทความตอนที่ {episode}: {ARTICLES[episode]["title"]}'], check=True)
    subprocess.run(['git', 'push', 'origin', 'main'], check=True)
    print(f"✅ Push สําเร็จ!")

def update_state(episode):
    """อัปเดตสถานะว่าตอนไหนแล้ว"""
    state = {}
    if Path(STATE_FILE).exists():
        with open(STATE_FILE, 'r') as f:
            state = json.load(f)

    state['last_published'] = episode
    state[f'episode_{episode}'] = {
        'published_at': datetime.now().isoformat(),
        'title': ARTICLES[episode]['title']
    }

    with open(STATE_FILE, 'w') as f:
        json.dump(state, f, indent=2, ensure_ascii=False)

def run_episode(episode):
    """รันบทความตอนที่กําหนด"""
    if episode not in ARTICLES:
        print(f"❌ ไม่มีบทความตอนที่ {episode}")
        return

    article = ARTICLES[episode]

    # 1. สร้างรูป
    image_path = f"{IMAGES_DIR}/{episode:02d}-{article['slug']}.jpg"
    Path(IMAGES_DIR).mkdir(parents=True, exist_ok=True)
    generate_image(episode, article['prompt_image'], image_path)

    # 2. โหลด content (จากไฟล์หรือ inline)
    content = load_article_content(article)

    # 3. บันทึก .md
    save_markdown(episode, content)

    # 4. อัปโหลด WordPress
    post_url = upload_wordpress(episode, article['title'], content, image_path, article['slug'])

    # 4. Push GitHub
    push_to_github(episode)

    # 5. อัปเดต state
    update_state(episode)

    print(f"🎉 บทความตอนที่ {episode} เสร็จสมบูรณ์!")

def run_next():
    """รันตอนถัดไปที่ยังไม่ได้เผยแพร่"""
    state = {}
    if Path(STATE_FILE).exists():
        with open(STATE_FILE, 'r') as f:
            state = json.load(f)

    last = state.get('last_published', 0)
    next_ep = last + 1

    if next_ep > len(ARTICLES):
        print(f"✅ บทความทั้งหมด {len(ARTICLES)} ตอนเผยแพร่แล้ว!")
        return

    run_episode(next_ep)

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument('--episode', type=int, help='รันบทความตอนที่ X')
    parser.add_argument('--auto', action='store_true', help='รันตอนถัดไปที่ยังไม่ได้เผยแพร่')
    args = parser.parse_args()

    if args.episode:
        run_episode(args.episode)
    elif args.auto:
        run_next()
    else:
        print("ใช้: python3 solar-blog-generator.py --episode 1")
        print("   หรือ: python3 solar-blog-generator.py --auto")
